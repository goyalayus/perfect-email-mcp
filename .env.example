# Required
CODEX_EMAIL_ADDRESS=your_email@gmail.com
CODEX_EMAIL_PASSWORD=your_app_password

# Usually required (fallback recipient)
CODEX_EMAIL_TO=recipient@example.com

# Optional auth override
CODEX_EMAIL_USERNAME=your_email@gmail.com

# SMTP (defaults are Gmail-friendly)
CODEX_EMAIL_SMTP_HOST=smtp.gmail.com
CODEX_EMAIL_SMTP_PORT=465
CODEX_EMAIL_SMTP_STARTTLS=false

# IMAP (defaults are Gmail-friendly)
CODEX_EMAIL_IMAP_HOST=imap.gmail.com
CODEX_EMAIL_IMAP_PORT=993
CODEX_EMAIL_IMAP_MAILBOX=INBOX

# Optional state dirs
CODEX_EMAIL_STATE_DIR=~/.codex/email-bridge/state
EMAIL_MCP_STATE_DIR=~/.codex/email-bridge/mcp-state

# Optional MCP behavior
EMAIL_MCP_PREWARM=true
EMAIL_MCP_PYTHON=python3
EMAIL_MCP_BRIDGE_SCRIPT=/absolute/path/to/email-mcp/bridge/email_bridge.py
